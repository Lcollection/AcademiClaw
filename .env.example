

# Added by skill
ASSISTANT_HAS_OWN_NUMBER=

# Added by skill
TELEGRAM_BOT_TOKEN=

# Added by skill
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Memory System (SQLite + LanceDB hybrid for semantic search)
# Enable semantic memory features
MEMORY_ENABLED=false

# Embedding API Configuration
# Option 1: Jina AI (recommended - 1M free tokens/month)
# Get API key at: https://jina.ai/
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.jina.ai/v1
EMBEDDING_MODEL=jina-embeddings-v3

# Option 2: OpenAI
# OPENAI_API_KEY=
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# Option 3: DeepSeek (note: DeepSeek does not provide embeddings API)
# Use Jina AI or OpenAI instead

# Memory search configuration
MEMORY_MAX_RESULTS=20
MEMORY_MIN_SCORE=0.7
MEMORY_BATCH_SIZE=32
MEMORY_SYNC_ON_WRITE=true
MEMORY_GRACEFUL_DEGRADATION=true
MEMORY_ENABLE_HYBRID=true
